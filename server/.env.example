# Redis (required — used by Socket.IO adapter and PresenceService)
# Obtain from your Redis provider (Upstash, Render, Railway, etc.)
REDIS_URL=redis://your-redis-host:6379

# Email Configuration (Gmail)
GMAIL_USER=your-email@gmail.com

EMAIL_FROM=your-email@gmail.com

# Company Info for Email Templates
COMPANY_NAME=Your Company Name
COMPANY_ADDRESS=Your Company Address

# ── AI (OpenRouter) ──────────────────────────────────────────────────────────
# Required: Get your API key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Optional: Comma-separated list of models to try in order before openrouter/auto
# Defaults to: meta-llama/llama-3.1-8b-instruct:free,mistralai/mistral-7b-instruct:free,google/gemma-2-9b-it:free
# AI_MODELS=meta-llama/llama-3.1-8b-instruct:free,mistralai/mistral-7b-instruct:free

# Optional: Per-model request timeout in milliseconds (default: 25000)
# AI_REQUEST_TIMEOUT_MS=25000

# Optional: Max AI requests per user per 60-second window (default: 10)
# AI_RATE_LIMIT_MAX=10

# Optional: Your app's public URL (sent as HTTP-Referer to OpenRouter)
# APP_URL=https://docsy-client.vercel.app